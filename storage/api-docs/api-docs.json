{
    "openapi": "3.0.0",
    "info": {
        "title": "Translation Management API",
        "description": "API documentation for authentication, translations, locales, approval, bulk operations, and export.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api",
            "description": "Local API Server"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "operationId": "loginUser",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginSuccessResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Invalid credentials."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout current user",
                "operationId": "logoutUser",
                "responses": {
                    "200": {
                        "description": "Logout successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/MessageResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/export/{locale}": {
            "get": {
                "tags": [
                    "Export"
                ],
                "summary": "Export translations by locale",
                "operationId": "exportTranslations",
                "parameters": [
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Locale code",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "en"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Exported translations",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ExportResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/locales": {
            "get": {
                "tags": [
                    "Locales"
                ],
                "summary": "List all locales",
                "operationId": "listLocales",
                "responses": {
                    "200": {
                        "description": "List of locales",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Locale"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Locales"
                ],
                "summary": "Create locale",
                "operationId": "storeLocale",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/StoreLocaleRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Locale created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Locale"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/locales/{locale}": {
            "get": {
                "tags": [
                    "Locales"
                ],
                "summary": "Get one locale",
                "operationId": "showLocale",
                "parameters": [
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Locale ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Locale details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Locale"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Locales"
                ],
                "summary": "Delete locale",
                "operationId": "deleteLocale",
                "parameters": [
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Locale ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Deleted"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Locales"
                ],
                "summary": "Update locale",
                "operationId": "updateLocale",
                "parameters": [
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Locale ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateLocaleRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Locale updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Locale"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/translations": {
            "get": {
                "tags": [
                    "Translations"
                ],
                "summary": "Get paginated translations",
                "operationId": "listTranslations",
                "responses": {
                    "200": {
                        "description": "Paginated translation list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TranslationListResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Translations"
                ],
                "summary": "Create translation",
                "operationId": "storeTranslation",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateTranslationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Translation"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/translations/{translation}": {
            "get": {
                "tags": [
                    "Translations"
                ],
                "summary": "Get one translation",
                "operationId": "showTranslation",
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "description": "Translation ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Translation details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Translation"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Translations"
                ],
                "summary": "Delete translation",
                "operationId": "deleteTranslation",
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Deleted"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Translations"
                ],
                "summary": "Update translation",
                "operationId": "updateTranslation",
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateTranslationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Translation"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/translations/search": {
            "post": {
                "tags": [
                    "Translations"
                ],
                "summary": "Search translations",
                "operationId": "searchTranslations",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SearchTranslationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Search results",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TranslationListResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/translations/bulk": {
            "post": {
                "tags": [
                    "Translations"
                ],
                "summary": "Bulk create translations",
                "operationId": "bulkCreateTranslations",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BulkTranslationsRequest"
                            },
                            "examples": {
                                "multiple_translations": {
                                    "summary": "Bulk create multiple translations",
                                    "value": {
                                        "translations": [
                                            {
                                                "key": "home.title",
                                                "locale": "en",
                                                "value": "Home",
                                                "tags": [
                                                    "web"
                                                ]
                                            },
                                            {
                                                "key": "home.title",
                                                "locale": "fr",
                                                "value": "Accueil",
                                                "tags": [
                                                    "web"
                                                ]
                                            },
                                            {
                                                "key": "auth.login.button",
                                                "locale": "en",
                                                "value": "Login",
                                                "tags": [
                                                    "web",
                                                    "mobile"
                                                ]
                                            }
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Bulk created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BulkTranslationResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/translations/{translation}/approve": {
            "patch": {
                "tags": [
                    "Translations"
                ],
                "summary": "Approve translation",
                "operationId": "approveTranslation",
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Approved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Translation"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "LoginRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password"
                    }
                },
                "type": "object"
            },
            "LoginSuccessResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Login successful."
                    },
                    "token": {
                        "type": "string",
                        "example": "1|long-sanctum-token"
                    }
                },
                "type": "object"
            },
            "MessageResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Logout successful."
                    }
                },
                "type": "object"
            },
            "TagResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Web"
                    },
                    "slug": {
                        "type": "string",
                        "example": "web"
                    },
                    "description": {
                        "type": "string",
                        "example": "Web context",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Translation": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "key": {
                        "type": "string",
                        "example": "auth.login.title"
                    },
                    "locale": {
                        "type": "string",
                        "example": "en"
                    },
                    "value": {
                        "type": "string",
                        "example": "Login"
                    },
                    "is_approved": {
                        "type": "boolean",
                        "example": true
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/TagResource"
                        }
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "TranslationListResponse": {
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Translation"
                        }
                    },
                    "meta": {
                        "properties": {
                            "current_page": {
                                "type": "integer",
                                "example": 1
                            },
                            "last_page": {
                                "type": "integer",
                                "example": 10
                            },
                            "per_page": {
                                "type": "integer",
                                "example": 50
                            },
                            "total": {
                                "type": "integer",
                                "example": 500
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "CreateTranslationRequest": {
                "required": [
                    "key",
                    "locale",
                    "value"
                ],
                "properties": {
                    "key": {
                        "type": "string",
                        "example": "auth.login.title"
                    },
                    "locale": {
                        "type": "string",
                        "example": "en"
                    },
                    "value": {
                        "type": "string",
                        "example": "Login"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "example": [
                            "web",
                            "mobile"
                        ]
                    },
                    "key_description": {
                        "type": "string",
                        "example": "Login page title"
                    }
                },
                "type": "object"
            },
            "UpdateTranslationRequest": {
                "required": [
                    "value"
                ],
                "properties": {
                    "value": {
                        "type": "string",
                        "example": "Sign In"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "example": [
                            "web"
                        ]
                    },
                    "is_approved": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "SearchTranslationRequest": {
                "required": [
                    "search_type",
                    "query"
                ],
                "properties": {
                    "search_type": {
                        "type": "string",
                        "example": "key",
                        "enum": [
                            "key",
                            "content",
                            "tag"
                        ]
                    },
                    "query": {
                        "type": "string",
                        "example": "auth.login"
                    },
                    "locale": {
                        "type": "string",
                        "example": "en"
                    },
                    "page": {
                        "type": "integer",
                        "example": 1
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 20
                    }
                },
                "type": "object"
            },
            "BulkTranslationsRequest": {
                "required": [
                    "translations"
                ],
                "properties": {
                    "translations": {
                        "type": "array",
                        "items": {
                            "required": [
                                "key",
                                "locale",
                                "value"
                            ],
                            "properties": {
                                "key": {
                                    "type": "string",
                                    "example": "home.title"
                                },
                                "locale": {
                                    "type": "string",
                                    "example": "en"
                                },
                                "value": {
                                    "type": "string",
                                    "example": "Home"
                                },
                                "tags": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    },
                                    "example": [
                                        "web"
                                    ]
                                },
                                "key_description": {
                                    "type": "string",
                                    "example": "Homepage title"
                                }
                            },
                            "type": "object"
                        }
                    }
                },
                "type": "object"
            },
            "BulkTranslationResponse": {
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Translation"
                        }
                    }
                },
                "type": "object"
            },
            "ExportResponse": {
                "properties": {
                    "locale": {
                        "type": "string",
                        "example": "en"
                    },
                    "translations": {
                        "type": "object",
                        "additionalProperties": true
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "Locale": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "code": {
                        "type": "string",
                        "example": "en"
                    },
                    "name": {
                        "type": "string",
                        "example": "English"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "StoreLocaleRequest": {
                "required": [
                    "code",
                    "name"
                ],
                "properties": {
                    "code": {
                        "type": "string",
                        "example": "fr"
                    },
                    "name": {
                        "type": "string",
                        "example": "French"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "UpdateLocaleRequest": {
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "French"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": false
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Use the Sanctum API token returned by /login. Example: Bearer 1|xxxx",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Authentication endpoints"
        },
        {
            "name": "Translations",
            "description": "Translation CRUD and workflows"
        },
        {
            "name": "Locales",
            "description": "Locale management endpoints"
        },
        {
            "name": "Export",
            "description": "Export translations by locale"
        }
    ]
}